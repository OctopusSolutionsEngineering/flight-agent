# ===== LLM =====
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# ===== OpenSky (optional — works anonymously with rate limits) =====
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# ===== Aviationstack (optional — for schedules/delays) =====
AVIATIONSTACK_API_KEY=

# ===== Azure =====
USE_APP_CONFIGURATION=false
AZURE_APPCONFIG_ENDPOINT=
APPCONFIG_LABEL=prod
USE_KEY_VAULT=false
AZURE_KEY_VAULT_URL=

# ===== App =====
LOG_LEVEL=INFO

# ===== Caching =====
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_AIRPORT=86400
CACHE_TTL_LIVE_STATE=15
CACHE_TTL_FLIGHTS_BY_AIRPORT=60
CACHE_TTL_FLIGHT_TRACK=60
